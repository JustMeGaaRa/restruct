{
    "name": "@restruct/structurizr-react",
    "version": "0.1.0-alpha.0",
    "type": "module",
    "main": "./dist/cjs/index.cjs",
    "module": "./dist/esm/index.mjs",
    "types": "./dist/esm/index.d.mts",
    "exports": {
        ".": {
            "require": {
                "types": "./dist/cjs/index.d.cts",
                "default": "./dist/cjs/index.cjs"
            },
            "import": {
                "types": "./dist/esm/index.d.mts",
                "default": "./dist/esm/index.mjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "test": "vitest",
        "lint": "eslint .",
        "publish:dry-run": "npm publish --tag alpha --dry-run",
        "publish:alpha": "npm publish --tag alpha --access public"
    },
    "dependencies": {
        "@dagrejs/dagre": "^1.1.4",
        "@restruct/react-svg": "workspace:*",
        "@restruct/structurizr-dsl": "workspace:*",
        "cytoscape": "^3.33.1",
        "elkjs": "^0.11.1"
    },
    "devDependencies": {
        "@restruct/eslint-config": "workspace:*",
        "@restruct/typescript-config": "workspace:*",
        "@tsdown/css": "^0.21.2",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "tsdown": "^0.21.2",
        "vitest": "^2.1.1"
    },
    "peerDependencies": {
        "@types/react": "^19.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    }
}
